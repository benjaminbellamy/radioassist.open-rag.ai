{
  "name": "radioassist-open-rag",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Demo front end for an OpenRAG instance, embedded in Radio Assist.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "server": "tsx server/index.ts",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "wavesurfer.js": "^7.8.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
