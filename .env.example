# OpenRAG demo instance
OPENRAG_API_URL=https://demo.open-rag.ai

# API token. NEVER commit the real .env. The token stays server-side and is
# never exposed to the browser.
OPENRAG_API_TOKEN=your-token-here

# Optional: restrict the partition listbox to a comma-separated allowlist.
# Leave empty to show every partition the token can access.
OPENRAG_PARTITIONS=

# Backend proxy port and bind address.
# HOST defaults to 127.0.0.1 (loopback) so only a local reverse proxy can reach
# it. Set HOST=0.0.0.0 only if you deliberately want it exposed.
PORT=8787
HOST=127.0.0.1
